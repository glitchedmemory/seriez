generator client {
  provider = "prisma-client"
  output   = "../.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model SearchLog {
  id        BigInt   @id @default(autoincrement())
  query     String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("search_logs")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  role         String   @default("user") // user | admin
  isPremium    Boolean  @default(false) @map("is_premium")
  avatarUrl    String?
  backgroundUrl String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  reviews      Review[]
  lists        UserList[]

  followers    Follow[]  @relation("following")
  following    Follow[]  @relation("follower")

  @@map("users")
}

model MediaTracking {
  id           String   @id @default(uuid())
  username     String
  tmdbId       Int      @map("tmdb_id")
  anilistId    Int?     @map("anilist_id")
  mediaType    String   @map("media_type") // movie, tv, anime
  seasonNumber Int      @default(0) @map("season_number") // 0=movie, 1+=TV/anime season
  status       String   // watching, completed, plan_to_watch, on_hold, dropped
  rating       Float?   // 0.5 ~ 5.0
  progress     Int?     // episode count for TV
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([username, tmdbId, mediaType, seasonNumber])
  @@map("media_trackings")
}

model Review {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  username   String   @default("Anonymous")
  tmdbId     Int      @map("tmdb_id")
  mediaType  String   @map("media_type")
  content    String
  rating     Int      @default(0)
  hasSpoiler Boolean  @default(false) @map("has_spoiler")
  likesCount Int      @default(0) @map("likes_count")
  isHidden   Boolean  @default(false) @map("is_hidden")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model ReviewComment {
  id         BigInt    @id @default(autoincrement())
  reviewId   String    @map("review_id") @db.Uuid
  username   String
  content    String
  parentId   BigInt?   @map("parent_id")
  likesCount Int       @default(0) @map("likes_count")
  isHidden   Boolean   @default(false) @map("is_hidden")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([reviewId])
  @@index([createdAt(sort: Desc)])
  @@map("review_comments")
}

model CommentLike {
  id        BigInt    @id @default(autoincrement())
  commentId BigInt    @map("comment_id")
  username  String
  createdAt DateTime  @default(now()) @map("created_at")

  @@unique([commentId, username])
  @@index([commentId])
  @@index([username])
  @@map("comment_likes")
}

model Report {
  id               BigInt    @id @default(autoincrement())
  targetType       String    @map("target_type")
  targetId         String    @map("target_id")
  reporterUsername String    @map("reporter_username")
  reason           String?   @map("reason")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@unique([targetType, targetId, reporterUsername])
  @@index([targetType, targetId])
  @@index([reporterUsername])
  @@map("reports")
}

model EpisodeWatch {
  id            String   @id @default(uuid())
  username      String
  tmdbId        Int      @map("tmdb_id")
  seasonNumber  Int      @map("season_number")
  episodeNumber Int      @map("episode_number")
  watchedAt     DateTime @default(now()) @map("watched_at")

  @@unique([username, tmdbId, seasonNumber, episodeNumber])
  @@index([username, tmdbId])
  @@map("episode_watches")
}

model UserList {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  isPublic  Boolean  @default(true) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ListItem[]

  @@map("user_lists")
}

model ListItem {
  id           String   @id @default(uuid())
  listId       String   @map("list_id")
  tmdbId       Int      @map("tmdb_id")
  mediaType    String   @map("media_type")
  seasonNumber Int      @default(0) @map("season_number")
  addedAt      DateTime @default(now()) @map("added_at")

  list UserList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@map("list_items")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("follower", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

model AdminAction {
  id            BigInt    @id @default(autoincrement())
  action        String
  targetType    String    @map("target_type")
  targetId      String    @map("target_id")
  details       Json      @default("{}")
  adminUsername String    @map("admin_username")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([adminUsername])
  @@index([createdAt(sort: Desc)])
  @@index([targetType, targetId])
  @@map("admin_actions")
}
